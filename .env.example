# --- Core ---
# Used to sign session cookies. Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Email verification ---
# console = print the code to the server log (for local dev, no SMTP needed)
# smtp    = actually send via the SMTP settings below
EMAIL_MODE=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mydomain.com

# --- Have I Been Pwned ---
# Get a key at https://haveibeenpwned.com/API/Key  (leave blank to disable the breach module)
HIBP_API_KEY=

# --- App ---
APP_NAME=Footprint Lab
# Comma-separated. Keep this small for an educational tool.
RATE_LIMIT=10/hour

# Advanced OSINT research page (Maigret). Local only — keep this 0/unset in production.
ENABLE_RESEARCH=1
